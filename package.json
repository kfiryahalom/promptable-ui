{
  "name": "promptable-ui",
  "version": "0.1.2",
  "description": "AI-customizable dashboard widgets for React. Users describe what they want in natural language; your LLM or MCP server returns a WidgetConfig; the package renders it. Bring your own LLM.",
  "keywords": [
    "react",
    "dashboard",
    "widgets",
    "ai",
    "llm",
    "mcp",
    "natural-language",
    "data-visualization",
    "recharts",
    "generative-ui",
    "prompt"
  ],
  "license": "MIT",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm build",
    "dev": "pnpm --filter task-pulse dev",
    "dev:market": "pnpm --filter market-lens dev",
    "dev:fit": "pnpm --filter fit-board dev",
    "seed": "pnpm --filter task-pulse seed"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  }
}
